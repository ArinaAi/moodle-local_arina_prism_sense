<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/lecturebot/db" VERSION="20251213" COMMENT="XMLDB file for Moodle local/lecturebot"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd"
>
  <TABLES>
    <TABLE NAME="local_lecturebot_sources" COMMENT="Stores source PDF files uploaded for content generation per section">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="Course ID"/>
        <FIELD NAME="sectionid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="Section ID"/>
        <FIELD NAME="filename" TYPE="char" LENGTH="255" NOTNULL="true" SEQUENCE="false" COMMENT="Original filename"/>
        <FIELD NAME="fileitemid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="File item ID in Moodle files table"/>
        <FIELD NAME="filesize" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="File size in bytes"/>
        <FIELD NAME="title" TYPE="char" LENGTH="255" NOTNULL="false" SEQUENCE="false" COMMENT="Source title"/>
        <FIELD NAME="author" TYPE="char" LENGTH="255" NOTNULL="false" SEQUENCE="false" COMMENT="Source author"/>
        <FIELD NAME="is_scanned" TYPE="int" LENGTH="1" NOTNULL="false" SEQUENCE="false" COMMENT="Is this a scanned PDF (1) or digital PDF (0/null)"/>
        <FIELD NAME="batch_id" TYPE="char" LENGTH="255" NOTNULL="false" SEQUENCE="false" COMMENT="Backend batch upload ID for PDF processing"/>
        <FIELD NAME="upload_id" TYPE="char" LENGTH="36" NOTNULL="false" SEQUENCE="false" COMMENT="Per-file upload UUID returned by the backend uploadpdf endpoint"/>
        <FIELD NAME="processing_status" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="uploaded" SEQUENCE="false" COMMENT="Doc processing status: uploaded, processing, failed"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="Time created"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="Time modified"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="courseid" TYPE="foreign" FIELDS="courseid" REFTABLE="course" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="courseid_sectionid" UNIQUE="false" FIELDS="courseid, sectionid"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="local_lecturebot_content" COMMENT="Stores generated content state and metadata">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="Course ID"/>
        <FIELD NAME="sectionid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="Section ID where content was generated"/>
        <FIELD NAME="contenttype" TYPE="char" LENGTH="50" NOTNULL="true" SEQUENCE="false" COMMENT="Type: slide-deck, flashcards, mind-map, etc"/>
        <FIELD NAME="status" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="queued" SEQUENCE="false" COMMENT="Status: queued, generating, ready, published, error"/>
        <FIELD NAME="title" TYPE="char" LENGTH="255" NOTNULL="true" SEQUENCE="false" COMMENT="Content title"/>

        <FIELD NAME="generationdata" TYPE="text" NOTNULL="false" SEQUENCE="false" COMMENT="JSON data for generation request and response"/>
        <FIELD NAME="errormessage" TYPE="text" NOTNULL="false" SEQUENCE="false" COMMENT="Error message if generation failed"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="Time generation requested"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="Time last modified"/>
        <FIELD NAME="timepublished" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false" COMMENT="Time published to course"/>
        <FIELD NAME="approved" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0" SEQUENCE="false" COMMENT="Whether content is approved (0=no, 1=yes)"/>
        <FIELD NAME="approvedby" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false" COMMENT="User ID who approved the content"/>
        <FIELD NAME="timeapproved" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false" COMMENT="Timestamp when content was approved"/>
        <FIELD NAME="request_id" TYPE="char" LENGTH="255" NOTNULL="false" SEQUENCE="false" COMMENT="Backend request ID for async tracking via Kafka"/>
        <FIELD NAME="createdby" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false" COMMENT="User ID who generated the content"/>
        <FIELD NAME="publishedby" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false" COMMENT="User ID who published the content"/>
        <FIELD NAME="parent_content_id" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false" COMMENT="Reference to the original content ID if this is a regeneration"/>
        <FIELD NAME="feedback_id" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false" COMMENT="Reference to the feedback record that triggered this regeneration"/>
        <FIELD NAME="regen_count" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false" COMMENT="Azure folder index for this generation. Unique per section, assigned atomically at request time to prevent concurrent overwrites."/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="courseid" TYPE="foreign" FIELDS="courseid" REFTABLE="course" REFFIELDS="id"/>
        <KEY NAME="approvedby" TYPE="foreign" FIELDS="approvedby" REFTABLE="user" REFFIELDS="id"/>
        <KEY NAME="createdby" TYPE="foreign" FIELDS="createdby" REFTABLE="user" REFFIELDS="id"/>
        <KEY NAME="publishedby" TYPE="foreign" FIELDS="publishedby" REFTABLE="user" REFFIELDS="id"/>
        <KEY NAME="parent_content_id" TYPE="foreign" FIELDS="parent_content_id" REFTABLE="local_lecturebot_content" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="courseid_status" UNIQUE="false" FIELDS="courseid, status"/>
        <INDEX NAME="courseid_sectionid" UNIQUE="false" FIELDS="courseid, sectionid"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="local_lecturebot_tracking" COMMENT="Tracks student completion of content">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="User ID"/>
        <FIELD NAME="contentid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="Content ID"/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="Course ID"/>
        <FIELD NAME="status" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0" SEQUENCE="false" COMMENT="Completion status (1=complete)"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="Time created"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="Time modified"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="userid" TYPE="foreign" FIELDS="userid" REFTABLE="user" REFFIELDS="id"/>
        <KEY NAME="contentid" TYPE="foreign" FIELDS="contentid" REFTABLE="local_lecturebot_content" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="userid_contentid" UNIQUE="true" FIELDS="userid, contentid"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="local_lecturebot_feedback" COMMENT="Stores user feedback for content regeneration">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="contentid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="Original content ID the feedback is for"/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="Course ID"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="User ID who provided feedback"/>
        <FIELD NAME="feedback_type" TYPE="char" LENGTH="50" NOTNULL="true" DEFAULT="structured" SEQUENCE="false" COMMENT="Type of feedback: structured, rating, etc"/>
        <FIELD NAME="selected_categories" TYPE="text" NOTNULL="false" SEQUENCE="false" COMMENT="JSON array of selected feedback category IDs"/>
        <FIELD NAME="topics_needing_depth" TYPE="text" NOTNULL="false" SEQUENCE="false" COMMENT="JSON array of topics needing more detail"/>
        <FIELD NAME="topics_overexplained" TYPE="text" NOTNULL="false" SEQUENCE="false" COMMENT="JSON array of topics that are over-explained"/>
        <FIELD NAME="extra_topics" TYPE="text" NOTNULL="false" SEQUENCE="false" COMMENT="JSON array of extra/unwanted topics"/>
        <FIELD NAME="missing_subtopics" TYPE="text" NOTNULL="false" SEQUENCE="false" COMMENT="JSON array of missing subtopics/keywords"/>
        <FIELD NAME="reordered_flow" TYPE="text" NOTNULL="false" SEQUENCE="false" COMMENT="JSON array indicating the desired topic order"/>
        <FIELD NAME="rating" TYPE="int" LENGTH="1" NOTNULL="false" SEQUENCE="false" COMMENT="Optional star rating (1-5)"/>
        <FIELD NAME="comments" TYPE="text" NOTNULL="false" SEQUENCE="false" COMMENT="Optional free-text comments"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="Timestamp when feedback was submitted"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="contentid" TYPE="foreign" FIELDS="contentid" REFTABLE="local_lecturebot_content" REFFIELDS="id"/>
        <KEY NAME="courseid" TYPE="foreign" FIELDS="courseid" REFTABLE="course" REFFIELDS="id"/>
        <KEY NAME="userid" TYPE="foreign" FIELDS="userid" REFTABLE="user" REFFIELDS="id"/>
      </KEYS>
    </TABLE>
    <TABLE NAME="local_lecturebot_company_config" COMMENT="Stores per-company IOMAD config: API key and org wallet owner ID">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="companyid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="IOMAD company ID (mdl_company.id)"/>
        <FIELD NAME="api_key" TYPE="text" NOTNULL="false" SEQUENCE="false" COMMENT="Arina API key for this company"/>
        <FIELD NAME="org_wallet_owner_id" TYPE="char" LENGTH="100" NOTNULL="false" SEQUENCE="false" COMMENT="Credit Service org wallet owner UUID (JIT-created)"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="Time created"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="Time last modified"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="companyid" UNIQUE="true" FIELDS="companyid"/>
      </INDEXES>
    </TABLE>
  </TABLES>
</XMLDB>
